# =============================================================================
# Local prototype (default) — no GCP account or .env file required
# =============================================================================
#   npm install
#   npm run dev
#   Open http://localhost:3000
#
# The API serves synthetic biomarker rows unless BigQuery is configured below.
# Copy this file to .env.local if you want to override anything (optional).

# Force demo data even when GCP vars are set (optional)
# DEMO_MODE=true

# =============================================================================
# Optional — BigQuery via service account (recommended with service1@… key file)
# =============================================================================
# GOOGLE_APPLICATION_CREDENTIALS=.secrets/bigquery-sa.json
#
# =============================================================================
# Optional — connect BigQuery + Vertex later (same env names work on Cloud Run)
# =============================================================================
# GCP_PROJECT_ID=
# BIGQUERY_LOCATION=US
# BIGQUERY_DATASET=A2
# BIGQUERY_VIEW_NAMES=View_A,View_B
# BIGQUERY_TABLE_FQN=project.dataset.table
# BQ_COL_PATIENT_ID=patient_id
# BQ_COL_VISIT_DATE=visit_date
# BQ_COL_BIOMARKER=biomarker
# BQ_COL_VALUE=value
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-1.5-flash
# HUGGINGFACE_API_KEY=hf_xxx
# HUGGINGFACE_MODEL=google/medgemma-27b-text-it
